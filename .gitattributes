# Normalize line endings to LF inside the repo; check out native per-platform.
* text=auto

# Binary assets — never line-ending-normalize (corruption guard).
*.db   binary
*.sqlite binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.icns binary
*.exe  binary
*.dll  binary
*.wav  binary
*.mp3  binary
*.mp4  binary
*.woff binary
*.woff2 binary
*.ttf  binary
